PORT=5000

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
# gpt-4o-mini is fast and cost-effective for most requests; CascadeFlow will upgrade as needed
OPENAI_MODEL=gpt-4o-mini

# ─── Hindsight Persistent Memory (Milestone 5) ──────────────────────────────
# Cloud (recommended): Sign up at https://ui.hindsight.vectorize.io
#   → Copy your API URL and API key from the dashboard
HINDSIGHT_BASE_URL=https://api.hindsight.vectorize.io
HINDSIGHT_API_KEY=your_hindsight_api_key

# Self-hosted Docker alternative:
# HINDSIGHT_BASE_URL=http://localhost:8888
# HINDSIGHT_API_KEY=   (leave empty for local Docker)

# ─── CORS ────────────────────────────────────────────────────────────────────
# Add your production frontend URL so the backend CORS allowlist accepts it
FRONTEND_URL=https://your-foundermind-app.vercel.app

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Auth endpoints (register/login): max requests per window per IP
# Defaults: 5 req per 60 000 ms (1 min). In development, limits are x10.
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=60000

# Chat endpoint: max requests per window per authenticated user/IP
# Defaults: 60 req per 60 000 ms (1 min). In development, limits are x10.
RATE_LIMIT_CHAT_MAX=60
RATE_LIMIT_CHAT_WINDOW_MS=60000

# NODE_ENV: set to "production" on your hosting platform to enable strict limits
NODE_ENV=development
